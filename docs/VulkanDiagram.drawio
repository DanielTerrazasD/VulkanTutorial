        </mxCell>
        <mxCell id="RH8K27Ynl2wi6o8nquaF-5" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;«enumeration»&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;VkQueryPipelineStatisticFlags&lt;/div&gt;" vertex="1">
