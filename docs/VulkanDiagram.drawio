        <mxCell id="3WTH8SaacucZ36tMoFGV-29" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#cdeb8b;strokeColor=#36393d;fontSize=10;" value="Memory Heap" vertex="1">
