        <mxCell id="Z1z3IJchIK2mPZd4wL81-13" connectable="0" parent="Z1z3IJchIK2mPZd4wL81-12" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="&lt;i&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;vkCreateDescriptorPool()&lt;/font&gt;&lt;/i&gt;" vertex="1">
