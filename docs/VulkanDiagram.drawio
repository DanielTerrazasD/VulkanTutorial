        <mxCell id="3WTH8SaacucZ36tMoFGV-27" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=10;" value="VkSampler" vertex="1">
