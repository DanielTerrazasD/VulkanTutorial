        <mxCell id="xhOm43dpNXqUqvkQsrzt-9" connectable="0" parent="xhOm43dpNXqUqvkQsrzt-8" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="&lt;font style=&quot;font-size: 8px;&quot;&gt;&lt;i&gt;used for creation of:&lt;/i&gt;&lt;/font&gt;" vertex="1">
