        <mxCell id="RH8K27Ynl2wi6o8nquaF-13" connectable="0" parent="RH8K27Ynl2wi6o8nquaF-12" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="&lt;span style=&quot;font-size: 8px;&quot;&gt;&lt;i&gt;vkCreateQueryPool()&lt;/i&gt;&lt;/span&gt;" vertex="1">
