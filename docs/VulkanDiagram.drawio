        <mxCell id="3WTH8SaacucZ36tMoFGV-146" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;VkEvent&lt;/span&gt;&lt;/h1&gt;" vertex="1">
