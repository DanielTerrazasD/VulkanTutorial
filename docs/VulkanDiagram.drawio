        <mxCell id="Z1z3IJchIK2mPZd4wL81-11" parent="1" style="html=1;whiteSpace=wrap;" value="&lt;span style=&quot;font-weight: 700;&quot;&gt;VkDescriptorPool&lt;/span&gt;" vertex="1">
